{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextPackValidationReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "context_pack_id",
    "validated_at",
    "validator",
    "status",
    "checks",
    "errors",
    "warnings",
    "metadata"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^ctxval_[0-9a-f]{24}$" },
    "schema_version": { "const": "1.0.0" },
    "context_pack_id": { "type": "string", "pattern": "^ctx_[0-9a-f]{24}$" },
    "validated_at": { "type": "string", "minLength": 1 },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "tool", "version"],
      "properties": {
        "agent": { "type": "string", "minLength": 1 },
        "tool": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "status": { "enum": ["pass", "fail"] },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_present",
        "primary_evidence_present",
        "current_memory_active",
        "stale_memory_separated",
        "taste_present_for_taste_sensitive_task",
        "state_present",
        "permission_policy_present",
        "forbidden_actions_enforced",
        "no_worker_runtime_fields",
        "no_gbrain_write_authority",
        "receipt_consistent"
      ],
      "properties": {
        "evidence_present": { "enum": ["pass", "fail"] },
        "primary_evidence_present": { "enum": ["pass", "fail"] },
        "current_memory_active": { "enum": ["pass", "fail"] },
        "stale_memory_separated": { "enum": ["pass", "fail"] },
        "taste_present_for_taste_sensitive_task": { "enum": ["pass", "fail", "not_applicable"] },
        "state_present": { "enum": ["pass", "fail"] },
        "permission_policy_present": { "enum": ["pass", "fail"] },
        "forbidden_actions_enforced": { "enum": ["pass", "fail"] },
        "no_worker_runtime_fields": { "enum": ["pass", "fail"] },
        "no_gbrain_write_authority": { "enum": ["pass", "fail"] },
        "receipt_consistent": { "enum": ["pass", "fail"] }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "related_ids"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "related_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "pass" } } },
      "then": { "properties": { "errors": { "maxItems": 0 } } }
    },
    {
      "if": { "properties": { "status": { "const": "fail" } } },
      "then": { "properties": { "errors": { "minItems": 1 } } }
    }
  ]
}
