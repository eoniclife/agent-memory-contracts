{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eoniclife.github.io/agent-memory-contracts/schemas/decision_ledger_entry.schema.json",
  "title": "DecisionLedgerEntry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "schema_version", "ledger_type", "status", "confidence", "scope", "source_record_ids", "episode_record_ids", "evidence_span_ids", "candidate_ids", "reducer_decision_id", "observed_at", "asserted_at", "valid_from", "valid_until", "stale_after", "created_at", "updated_at", "supersedes", "superseded_by", "metadata", "decision_text", "decision_scope", "alternatives_considered", "rationale_text", "owner", "reversibility"],
  "properties": {
    "id": {"type": "string", "pattern": "^dec_[0-9a-f]{24}$"},
    "schema_version": {"const": "1.0.0"},
    "ledger_type": {"const": "decision"},
    "status": {"type": "string", "enum": ["active", "stale", "superseded", "retracted", "contested", "archived"]},
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "scope": {"type": "string", "enum": ["global", "project", "person", "company", "domain", "source_local", "context_specific"]},
    "source_record_ids": {"type": "array", "items": {"type": "string", "pattern": "^src_[0-9a-f]{16,}$"}},
    "episode_record_ids": {"type": "array", "items": {"type": "string", "pattern": "^ep_[0-9a-f]{16,}$"}},
    "evidence_span_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^span_[0-9a-f]{16,}$"}},
    "candidate_ids": {"type": "array", "items": {"type": "string", "pattern": "^cand_"}},
    "reducer_decision_id": {"type": "string", "pattern": "^redmem_[0-9a-f]{24}$"},
    "observed_at": {"type": ["string", "null"], "format": "date-time"},
    "asserted_at": {"type": ["string", "null"], "format": "date-time"},
    "valid_from": {"type": ["string", "null"], "format": "date-time"},
    "valid_until": {"type": ["string", "null"], "format": "date-time"},
    "stale_after": {"type": ["string", "null"], "format": "date-time"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "supersedes": {"type": "array", "items": {"type": "string", "pattern": "^(fact|pref|dec)_[0-9a-f]{24}$"}},
    "superseded_by": {"type": "array", "items": {"type": "string", "pattern": "^(fact|pref|dec)_[0-9a-f]{24}$"}},
    "metadata": {"type": "object"},
    "decision_text": {"type": "string", "minLength": 1},
    "decision_scope": {"type": "string", "enum": ["project", "architecture", "personal", "operational", "other"]},
    "alternatives_considered": {"type": "array", "items": {"type": "string"}},
    "rationale_text": {"type": ["string", "null"]},
    "owner": {"type": ["string", "null"]},
    "reversibility": {"type": "string", "enum": ["low", "medium", "high", "unknown"]}
  }
}
