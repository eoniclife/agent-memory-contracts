{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eoniclife.github.io/agent-memory-contracts/schemas/memory_reducer_decision.schema.json",
  "title": "MemoryReducerDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "schema_version", "decision_type", "target_candidate_ids", "target_ledger_entry_ids", "evidence_span_ids", "rationale", "decided_by", "decided_at", "confidence", "risk_class", "checks", "metadata"],
  "properties": {
    "id": {"type": "string", "pattern": "^redmem_[0-9a-f]{24}$"},
    "schema_version": {"const": "1.0.0"},
    "decision_type": {"type": "string", "enum": ["promote", "reject", "supersede", "retract", "contest", "archive"]},
    "target_candidate_ids": {"type": "array", "items": {"type": "string", "pattern": "^cand_"}},
    "target_ledger_entry_ids": {"type": "array", "items": {"type": "string", "pattern": "^(fact|pref|dec)_[0-9a-f]{24}$"}},
    "evidence_span_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^span_[0-9a-f]{16,}$"}},
    "rationale": {"type": "string", "minLength": 1},
    "decided_by": {"type": "object", "additionalProperties": false, "required": ["agent", "model", "tool", "prompt_ref"], "properties": {"agent": {"type": "string", "minLength": 1}, "model": {"type": "string", "minLength": 1}, "tool": {"type": ["string", "null"]}, "prompt_ref": {"type": ["string", "null"]}}},
    "decided_at": {"type": "string", "format": "date-time"},
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "risk_class": {"type": "string", "enum": ["low", "medium", "high"]},
    "checks": {"type": "object", "additionalProperties": false, "required": ["provenance", "temporal_validity", "contradiction_scan", "privacy", "usefulness"], "properties": {"provenance": {"type": "string", "enum": ["pass", "fail", "unknown"]}, "temporal_validity": {"type": "string", "enum": ["pass", "fail", "unknown"]}, "contradiction_scan": {"type": "string", "enum": ["pass", "fail", "unknown"]}, "privacy": {"type": "string", "enum": ["pass", "fail", "unknown"]}, "usefulness": {"type": "string", "enum": ["pass", "fail", "unknown"]}}},
    "metadata": {"type": "object"}
  }
}
