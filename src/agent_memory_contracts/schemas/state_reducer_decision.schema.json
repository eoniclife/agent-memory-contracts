{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StateReducerDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "decision_type",
    "target_project_state_ids",
    "target_core_state_ids",
    "source_record_ids",
    "episode_record_ids",
    "evidence_span_ids",
    "ledger_entry_ids",
    "taste_card_ids",
    "rationale",
    "decided_by",
    "decided_at",
    "confidence",
    "risk_class",
    "checks",
    "metadata"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^redstate_[0-9a-f]{24,}$" },
    "schema_version": { "const": "1.0.0" },
    "decision_type": { "enum": ["promote", "reject", "supersede", "retract", "contest", "archive"] },
    "target_project_state_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^projstate_" }
    },
    "target_core_state_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^corestate_" }
    },
    "source_record_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^src_" }
    },
    "episode_record_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^ep_" }
    },
    "evidence_span_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^span_" }
    },
    "ledger_entry_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^(fact_|pref_|dec_)" }
    },
    "taste_card_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^taste_" }
    },
    "rationale": { "type": "string", "minLength": 1 },
    "decided_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "model", "tool", "prompt_ref"],
      "properties": {
        "agent": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "tool": { "type": ["string", "null"] },
        "prompt_ref": { "type": ["string", "null"] }
      }
    },
    "decided_at": { "type": "string", "format": "date-time" },
    "confidence": { "enum": ["low", "medium", "high"] },
    "risk_class": { "enum": ["low", "medium", "high"] },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provenance", "temporal_validity", "state_consistency", "privacy", "usefulness"],
      "properties": {
        "provenance": { "enum": ["pass", "fail", "unknown"] },
        "temporal_validity": { "enum": ["pass", "fail", "unknown"] },
        "state_consistency": { "enum": ["pass", "fail", "unknown"] },
        "privacy": { "enum": ["pass", "fail", "unknown"] },
        "usefulness": { "enum": ["pass", "fail", "unknown"] }
      }
    },
    "metadata": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "decision_type": { "const": "reject" } } },
      "then": {
        "properties": {
          "target_project_state_ids": { "maxItems": 0 },
          "target_core_state_ids": { "maxItems": 0 }
        }
      }
    },
    {
      "if": { "properties": { "decision_type": { "enum": ["retract", "contest", "archive"] } } },
      "then": {
        "anyOf": [
          { "properties": { "target_project_state_ids": { "minItems": 1 } } },
          { "properties": { "target_core_state_ids": { "minItems": 1 } } }
        ]
      }
    }
  ]
}
